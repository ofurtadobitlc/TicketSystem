@using TicketSystem.Web.Models.Users
@model IEnumerable<UserListViewModel>

@{
    ViewData["Title"] = "Gestão de Usuários";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Criar Novo Usuário</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Email</th>
            <th>Perfil (Role)</th>
            <th>Status</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Email</td>
                <td><span class="badge bg-secondary">@item.RoleName</span></td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Ativo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inativo</span>
                    }
                </td>
                <td>
                    <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post" style="display:inline;">
                        @if (item.IsActive)
                        {
                            <button type="submit" class="btn btn-sm btn-outline-danger">Inativar</button>
                        }
                        else
                        {
                            <button type="submit" class="btn btn-sm btn-outline-success">Ativar</button>
                        }
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>