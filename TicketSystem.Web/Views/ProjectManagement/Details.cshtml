@model TicketSystem.Web.Models.ProjectManagement.ProjectDetailsViewModel

@* @{
    ViewData["Title"] = "Details";
} *@

<div class="container mt-1">
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-success"><i class="bi bi-chevron-left"></i> All</a>
        <h4 class="mb-0">Project: @Model.Title</h4>
    </div>
    <ul class="nav nav-tabs mt-2" id="myTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab" aria-controls="home" aria-selected="true">Home</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="members-tab" data-bs-toggle="tab" data-bs-target="#members" type="button" role="tab" aria-controls="members" aria-selected="false">
                Members
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="workflow-tab" data-bs-toggle="tab" data-bs-target="#workflow" type="button" role="tab" aria-controls="workflow" aria-selected="false">Workflow</button>
        </li>
    </ul>

    <div class="tab-content mt-3" id="myTabContent">
        <!-- HOME TAB -->
        <div class="tab-pane fade show active" id="home" role="tabpanel" aria-labelledby="home-tab">
            <div class="row">
                <div class="col-lg-8">
                    <div class="d-flex gap-2 my-3">
                        <div class="card text-center shadow-sm" style="width: 18rem;">
                            <div class="card-body">
                                <h2 class="display-4 fw-bold mb-0">@Model.TotalTickets</h2>
                                <p class="text-muted text-uppercase small">Tickets</p>
                            </div>
                        </div>
                        <div class="card text-center shadow-sm" style="width: 18rem;">
                            <div class="card-body">
                                <h2 class="display-4 fw-bold mb-0">@Model.ExistingMembers.Count()</h2>
                                <p class="text-muted text-uppercase small">Members</p>
                            </div>
                        </div>
                    </div>
                    <div class="card mb-3 shadow-sm">
                        <div class="card-header bg-light-subtle">
                            <h5 class="mb-0">Description</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text mt-3" style="white-space: pre-wrap;">@Model.Description</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 mt-4 mt-lg-0">
                    <div class="card mb-4 shadow-sm">
                        <div class="card-header bg-light-subtle">
                            <h5 class="mb-0">Details</h5>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">
                                    <span class="text-muted d-block small">Created By</span>
                                    <span>@Model.CreatedByName</span>
                                </li>
                                <li>
                                    <span class="text-muted d-block small">Start</span>
                                    <span>@Model.StartDate.ToString("dd/MM/yyyy")</span>
                                </li>
                                <li>
                                    <span class="text-muted d-block small">End</span>
                                    <span>@Model.EndDate?.ToString("dd/MM/yyyy")</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- MEMBERS TAB -->
        <div class="tab-pane fade" id="members" role="tabpanel" aria-labelledby="members-tab">
            <div class="d-flex justify-content-between gap-3 mt-3 mb-4">
                <h3>List of Members</h3>
                <div class="d-flex gap-2">
                    <button class="btn btn-secondary">Invite Link</button>
                    <button class="btn btn-primary">Add Member</button>
                </div>
            </div>
            <div class="row">
                <!-- col-12 for mobile (full width), col-lg-3 for large screens (1/4 width) -->
                <div class="col-12 col-lg-3">
                        @foreach (var member in Model.ExistingMembers)
                        {
                            <div class="list-group-item list-group-item-action d-flex align-items-center p-2 border-start-0 border-end-0 border-top-0">
                    
                                <!-- Avatar -->
                                <div class="avatar-circle me-3 flex-shrink-0">
                                    @member.Initials
                                </div>
                    
                                <!-- Member Name & Shield -->
                                <div class="d-flex gap-2 align-items-center flex-grow-1 min-width-0">
                                    <h6 class="mb-0 text-truncate">@member.MemberName</h6>
                        
                                    @if (member.RoleInProject == "Manager")
                                    {
                                        <i class="bi bi-shield-fill text-primary flex-shrink-0" title="Manager"></i>
                                    }
                                </div>

                                <!-- Dropdown Menu -->
                                <div class="dropdown flex-shrink-0">
                                    <button class="btn btn-sm btn-link text-muted p-1" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow">
                                        <li>
                                            <form asp-action="ChangeMemberRole" method="post">
                                                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                                <input type="hidden" name="memberId" value="@member.MemberId" />
                                                <input type="hidden" name="newRole" value="@(member.RoleInProject == "Manager" ? "Member" : "Manager")" />
                                                <button type="submit" class="dropdown-item">
                                                    @(member.RoleInProject == "Manager" ? "Demote to Member" : "Promote to Manager")
                                                </button>
                                            </form>
                                        </li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form asp-action="RemoveMember" method="post">
                                                <input type="hidden" name="projectId" value="@Model.ProjectId" />
                                                <input type="hidden" name="memberId" value="@member.MemberId" />
                                                <button type="submit" class="dropdown-item text-danger">Remove User</button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        }
                </div>
            </div>
        </div>
        
        <!-- WORKFLOW TAB -->
        <div class="tab-pane fade" id="workflow" role="tabpanel" aria-labelledby="workflow-tab">
           <h2 class="my-3">Workflow</h2>
            <div class="row">
                <div class="col-md-4">
                    <form asp-action="Create" method="post" id="workflowForm">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group mb-3">
                            <label asp-for="@Model.AddStatusForm.Name" class="control-label mb-3"></label>
                            <input asp-for="@Model.AddStatusForm.Name" class="form-control" />
                            <span asp-validation-for="@Model.AddStatusForm.Name" class="text-danger"></span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between">
                            <h4>Create Status</h4>
                            <button type="button" class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#statusModal">
                                Add Status
                            </button>
                        </div>
                        <table class="table table-bordered" id="statusTable">
                            <thead>
                                <tr>
                                    <th>Status</th>
                                    <th style="width: 100px;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.WorkflowStatuses != null)
                                {
                                    for (int i = 0; i < Model.WorkflowStatuses.Count; i++)
                                    {
                                        var isFixed = (Model.WorkflowStatuses[i].Name == "Open" || Model.WorkflowStatuses[i].Name == "Closed");
                                        <tr class="@(isFixed ? "fixed-row" : "custom-row")">
                                            <td class="status-name-cell">
                                                @Model.WorkflowStatuses[i].Name
                                                <input type="hidden" class="status-hidden-name" name="Statuses[@i].Name" value="@Model.WorkflowStatuses[i].Name" />
                                            </td>
                                            <td>
                                                @if (!isFixed)
                                                {
                                                    <button type="button" class="btn btn-danger btn-sm" onclick="removeStatus(this)">Remove</button>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">Fixed</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                        <div class="form-group">
                            <input type="submit" value="Create" class="btn btn-primary mt-4" />
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="statusModal" tabindex="-1" aria-labelledby="statusModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statusModalLabel">New Status</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="newStatusName" class="form-label">Status</label>
                    <input type="text" class="form-control" id="newStatusName" placeholder="Ex: Testing">
                    <span id="modalError" class="text-danger" style="display:none;">Name is required.</span>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="addStatus()">Add</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        function addStatus() {
            const nameInput = document.getElementById('newStatusName');
            const nameValue = nameInput.value.trim();
            const errorSpan = document.getElementById('modalError');

            if (!nameValue) {
                errorSpan.style.display = 'block';
                return;
            }
            errorSpan.style.display = 'none';

            const tbody = document.querySelector('#statusTable tbody');
            
            const tr = document.createElement('tr');
            tr.className = 'custom-row';
            tr.innerHTML = `
                <td class="status-name-cell">
                    ${nameValue}
                    <input type="hidden" class="status-hidden-name" value="${nameValue}" />
                </td>
                <td>
                    <button type="button" class="btn btn-danger btn-sm" onclick="removeStatus(this)">Remover</button>
                </td>
            `;
            
            // LÓGICA MUDADA AQUI:
            // Pegamos todas as linhas atuais e encontramos a última (que é o 'Close')
            const rows = tbody.querySelectorAll('tr');
            const lastRow = rows[rows.length - 1];
            
            // Insere a nova linha ANTES da última linha ('Closed')
            tbody.insertBefore(tr, lastRow);

            nameInput.value = '';

            const modalElement = document.getElementById('statusModal');
            const modalInstance = bootstrap.Modal.getInstance(modalElement) || new bootstrap.Modal(modalElement);
            modalInstance.hide();

            reindexStatuses();
        }

        function removeStatus(button) {
            const row = button.closest('tr');
            row.remove();
            reindexStatuses();
        }

        function reindexStatuses() {
            const rows = document.querySelectorAll('#statusTable tbody tr');
            
            // Isso vai reindexar o Open como [0], os do meio como [1, 2, ...] e o Close como [último]
            rows.forEach((row, index) => {
                const hiddenInput = row.querySelector('.status-hidden-name');
                if (hiddenInput) {
                    hiddenInput.setAttribute('name', `Statuses[${index}].Name`);
                }
            });
        }
        
        document.getElementById('statusModal').addEventListener('shown.bs.modal', function () {
            document.getElementById('newStatusName').focus();
        });
    </script>
}
